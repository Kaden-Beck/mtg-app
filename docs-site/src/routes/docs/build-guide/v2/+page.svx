*Expose the converter as a GraphQL mutation and build the upload → convert → download UI in React.*

#### backend/app/graphql/resolvers/converter.py

```python
import strawberry
from strawberry.types import Info
from app.services.converter import convert, CollectionFormat
from app.graphql.types import ConversionResultType

@strawberry.type
class ConverterMutation:
    @strawberry.mutation
    async def convert_csv(
        self,
        info: Info,
        csv: str,
        from_format: str,
        to_format: str,
    ) -> ConversionResultType:
        output, count = convert(csv, from_format, to_format)  # type: ignore
        return ConversionResultType(csv=output, count=count)
```

#### src/graphql/mutations/converter.graphql

```graphql
mutation ConvertCsv($csv: String!, $fromFormat: String!, $toFormat: String!) {
  convertCsv(csv: $csv, fromFormat: $fromFormat, toFormat: $toFormat) {
    csv
    count
  }
}
```

#### React converter component (key logic)

```tsx
import { useMutation } from "@apollo/client";
import { ConvertCsvDocument } from "@/graphql/graphql";

export function ConverterPage() {
  const [convert, { data, loading }] = useMutation(ConvertCsvDocument);

  const handleFile = async (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (!file) return;
    const csv = await file.text();
    await convert({ variables: { csv, fromFormat, toFormat } });
  };

  const handleDownload = () => {
    if (!data?.convertCsv.csv) return;
    const blob = new Blob([data.convertCsv.csv], { type: "text/csv" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = "converted.csv";
    a.click();
  };

  return (/* JSX with file input, format selects, download button */);
}
```

#### Implementation steps

1. Create `backend/app/graphql/resolvers/converter.py`
2. Add `ConverterMutation` to `schema.py`
3. Run `npm run codegen` to generate the TypeScript mutation hook
4. Build the converter UI with file input, from/to format selects, and download button
5. Test end-to-end: upload a real Manabox CSV, convert to Moxfield, download and verify
6. Commit: `git commit -m 'feat: converter resolver and UI'`

