### 10 · GraphQL Codegen

<div class="not-prose flex gap-2 mb-3">
  <span class="font-mono text-xs bg-blue-100 dark:bg-blue-950 text-blue-700 dark:text-blue-300 px-2 py-0.5 rounded">TypeScript</span>
  <span class="font-mono text-xs bg-purple-100 dark:bg-purple-950 text-purple-600 dark:text-purple-300 px-2 py-0.5 rounded">GraphQL</span>
</div>

*Generate TypeScript types from the Strawberry schema so the frontend has full type safety.*

#### Why codegen

Codegen introspects the live GraphQL schema and generates TypeScript types for every query and mutation you write. You write `.graphql` files in the frontend, run codegen, and get fully-typed hooks. This is the key advantage of GraphQL over tRPC for a two-language stack.

#### frontend/codegen.ts

```typescript
import type { CodegenConfig } from "@graphql-codegen/cli";

const config: CodegenConfig = {
  schema: "http://localhost:8000/graphql",
  documents: ["src/**/*.graphql"],
  generates: {
    "./src/graphql/": {
      preset: "client",
      presetConfig: {
        gqlTagName: "gql",
      },
    },
  },
};

export default config;
```

#### package.json script

```json
{
  "scripts": {
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch"
  }
}
```

#### src/graphql/queries/cards.graphql

```graphql
query SearchCards($query: String!, $limit: Int) {
  searchCards(query: $query, limit: $limit) {
    id
    name
    setCode
    setName
    manaCost
    cmc
    typeLine
    colorIdentity
    rarity
    priceUsd
    priceUsdFoil
    imageUris
  }
}

query CardById($id: String!) {
  cardById(id: $id) {
    id
    name
    oracleText
    legalities
    imageUris
  }
}
```

#### Using generated hooks

```tsx
// In a React component:
import { useQuery } from "@apollo/client";
import { SearchCardsDocument } from "@/graphql/graphql";

function CardSearch({ query }: { query: string }) {
  const { data, loading } = useQuery(SearchCardsDocument, {
    variables: { query, limit: 20 },
    skip: query.length < 2,
  });

  return <div>{data?.searchCards.map(c => c.name).join(", ")}</div>;
}
```

#### Implementation steps

1. Create `frontend/codegen.ts`
2. Add the `codegen` script to `package.json`
3. Make sure the FastAPI server is running
4. Create `src/graphql/queries/cards.graphql`
5. Run `npm run codegen` — confirm `src/graphql/graphql.ts` is generated
6. Run codegen after every schema change going forward
7. Commit: `git commit -m 'feat: graphql codegen setup'`

